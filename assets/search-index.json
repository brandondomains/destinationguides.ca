---
layout: null
---
[
{% assign docs = "" | split: "" %}
{% assign docs = docs | concat: site.countries | concat: site.regions | concat: site.cities | concat: site.attractions | concat: site.practical %}
{% for d in docs %}
  {
    "type": "{{ d.guide_type | escape }}",
    "title": "{{ d.title | escape }}",
    "url": "{{ d.url | relative_url }}",
    "dek": "{{ d.dek | default: d.description | strip_newlines | replace: '\"','\\\"' }}",
    "tags": [{% if d.tags %}{% for t in d.tags %}"{{ t | escape }}"{% unless forloop.last %},{% endunless %}{% endfor %}{% endif %}]
  }{% unless forloop.last %},{% endunless %}
{% endfor %}
]